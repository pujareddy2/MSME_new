# MSME Portal Environment Configuration Template
# Copy this to .env.local and fill in your actual values

# ===== DATABASE CONFIGURATION =====
# MySQL credentials - change these to your actual MySQL credentials
DB_USERNAME=root
DB_PASSWORD=puja
DB_HOST=localhost
DB_PORT=3306
DB_NAME=msme_portal

# ===== BACKEND CONFIGURATION =====
# Java home (Windows example shown)
JAVA_HOME=C:\Program Files\Java\jdk-21.0.10

# Backend server port (default: 8080)
SERVER_PORT=8080

# Backend API base URL
BACKEND_URL=http://localhost:8080

# ===== FRONTEND CONFIGURATION =====
# Frontend React app base URL
REACT_APP_API_BASE_URL=http://localhost:8080/api

# Frontend development port (default: 3000)
REACT_APP_PORT=3000

# ===== FILE UPLOAD CONFIGURATION =====
# Maximum file size for PPT/PDF uploads (in MB)
MAX_FILE_SIZE_MB=20

# Upload directory path
UPLOAD_DIR=./uploads/applications

# ===== PRODUCTION DEPLOYMENT =====
# Set these when deploying to production servers

# Production backend URL (for frontend to connect)
REACT_APP_API_BASE_URL_PROD=https://your-backend-domain.com/api

# Production database host (if different from localhost)
DB_HOST_PROD=your-db-host.com

# Production database credentials
DB_USERNAME_PROD=prod_user
DB_PASSWORD_PROD=your_secure_password

# Production Java home (Linux example)
# JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64

# ===== DEVELOPMENT SETTINGS =====
# Enable debug logs
DEBUG=true

# JPA/Hibernate setting for auto schema updates (use 'validate' in production)
JPA_DDL_AUTO=update

# Show SQL queries in logs
SHOW_SQL=false

# ===== CORS CONFIGURATION =====
# Allowed origins for CORS (comma-separated)
# Leave as * for development, restrict in production
CORS_ALLOWED_ORIGINS=*

# ===== NOTIFICATION SETTINGS =====
# Email for notifications (if email service added in future)
NOTIFICATION_EMAIL_FROM=noreply@msmehackathon.com

# ===== SESSION CONFIGURATION =====
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# ===== SECURITY =====
# JWT Secret (if JWT auth added in future)
JWT_SECRET=your_jwt_secret_key_here

# Password encoding strength (bcrypt rounds)
PASSWORD_ENCODING_STRENGTH=10
